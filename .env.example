# AiiDA Agent Environment Configuration

# Provider: 'ollama' (local), 'openai', 'anthropic', 'gemini'
AIIDA_AGENT_PROVIDER=

# Model: e.g. 'qwen3.5:2b', 'gemma3:4b', 'gpt-4o', etc.
AIIDA_AGENT_MODEL=

# Ollama server base URL (points to standard local Ollama server in WSL)
OLLAMA_BASE_URL=

# RAG embedding backend: 'ollama' or 'sentence-transformers'
AIIDA_AGENTS_EMBED_BACKEND=

# ChromaDB persistence path (default: .aiida_agent_vector_db)
AIIDA_AGENTS_VECTOR_DB_PATH=
