# aiida-agents environment configuration
#
# Every knob shares the AIIDA_AGENTS_ prefix, except OLLAMA_BASE_URL, which
# keeps its conventional unprefixed name so an existing Ollama setup works
# as-is. Copy this file to `.env` and fill in the values you need; unset
# variables fall back to the defaults shown in parentheses.

# --- Model (LLM) ---

# Provider: 'ollama' (local), 'openai', 'anthropic', 'openai-compatible'
AIIDA_AGENTS_PROVIDER=

# Model name, e.g. 'qwen3.5:2b', 'gpt-4o', 'claude-...'
AIIDA_AGENTS_MODEL=

# Base URL for 'openai-compatible' providers (DeepSeek, Together, vLLM, ...)
AIIDA_AGENTS_BASE_URL=

# API key for 'openai-compatible' providers (optional for keyless servers)
AIIDA_AGENTS_API_KEY=

# Ollama server base URL (default: http://localhost:11434/v1)
OLLAMA_BASE_URL=

# --- RAG (documentation retrieval) ---

# Embedding backend: 'ollama' or 'sentence-transformers' (default: ollama)
AIIDA_AGENTS_EMBED_BACKEND=

# Embedding model (default: mxbai-embed-large; used by the 'ollama' backend)
AIIDA_AGENTS_EMBED_MODEL=

# ChromaDB persistence path (default: .aiida_agents_vector_db)
AIIDA_AGENTS_VECTOR_DB_PATH=

# --- Logging ---

# Process-wide log level: DEBUG | INFO | WARNING | ERROR | CRITICAL (default: INFO)
AIIDA_AGENTS_LOG_LEVEL=

# --- MCP server ---

# Port for the streamable-http server (default: 8000)
AIIDA_AGENTS_PORT=
