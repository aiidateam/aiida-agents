# aiida-agents environment configuration
#
# Every knob shares the AIIDA_AGENTS_ prefix, except OLLAMA_BASE_URL, which
# keeps its conventional unprefixed name so an existing Ollama setup works
# as-is. Copy this file to `.env`, then uncomment and edit only the knobs you
# want to override. Each line below shows the built-in default, so an unedited
# copy behaves exactly like running with no `.env` at all.

# --- Model (LLM) ---

# Provider: 'ollama' (local), 'openai', 'anthropic', 'openrouter', or
# 'openai-compatible'. The cloud providers read their key from the environment
# (see the SDK keys below). 'openrouter' is a cloud aggregator (one key for many
# providers); cloud-only.
# AIIDA_AGENTS_PROVIDER=ollama

# Model name (provider-specific), e.g. 'qwen3.5:2b', 'gpt-4o', 'claude-...'.
# AIIDA_AGENTS_MODEL=qwen3.5:2b

# Endpoint for 'openai-compatible' providers (DeepSeek, Together, vLLM, ...).
# Required for that provider, ignored otherwise. No default.
# AIIDA_AGENTS_BASE_URL=https://api.deepseek.com/v1

# API key for an 'openai-compatible' endpoint. Optional for keyless servers
# (a dummy placeholder is used when unset). Never commit a real key.
# AIIDA_AGENTS_API_KEY=

# Cloud provider SDK keys (unprefixed, not AIIDA_AGENTS_*). Read by the settings
# layer and handed to the provider, so they work here in .env or as exported
# environment variables. Set the one your provider needs; never commit a real key.
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# OPENROUTER_API_KEY=

# Max output tokens per response (all providers). Raise if long runs truncate.
# AIIDA_AGENTS_MAX_TOKENS=8192

# Ollama context window (num_ctx), sent per request. Raise if long conversations
# get cut off. Ollama-only; must exceed AIIDA_AGENTS_MAX_TOKENS. Unset = default.
# AIIDA_AGENTS_CONTEXT_LENGTH=16384

# Ollama server endpoint, shared by the chat model and the RAG embeddings.
# OLLAMA_BASE_URL=http://localhost:11434/v1

# --- RAG (documentation retrieval) ---

# Embedding backend: 'ollama' or 'sentence-transformers'.
# AIIDA_AGENTS_EMBED_BACKEND=ollama

# Embedding model, used by the 'ollama' backend.
# AIIDA_AGENTS_EMBED_MODEL=mxbai-embed-large

# ChromaDB persistence directory.
# AIIDA_AGENTS_VECTOR_DB_PATH=.aiida_agents_vector_db

# --- Logging ---

# Process-wide log level: DEBUG, INFO, WARNING, ERROR, or CRITICAL.
# AIIDA_AGENTS_LOG_LEVEL=INFO

# --- MCP server ---

# Port for the streamable-http server.
# AIIDA_AGENTS_PORT=8000
